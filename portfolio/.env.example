# Resend — used by /api/send-email for the Contact form
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Recipient address — where contact form submissions land
TO_EMAIL=you@example.com

# Optional: override the "from" address.
# Default is "Portfolio Contact <onboarding@resend.dev>" (works without verifying a domain).
# To send from your own domain, verify it on Resend first.
# FROM_EMAIL=Portfolio <hello@yourdomain.com>
